<%= form_with(model: fill) do |form| %>
  <% if fill.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(fill.errors.count, "error") %> prohibited this fill from being saved:</h2>

      <ul>
        <% fill.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div data-controller="fill-form">
    <template data-fill-form-target="fillPreviewTemplate">
      <div class="O_FillPreview" data-fill-form-target="fillPreview"></div>
    </template>

    <template data-fill-form-target="colorPickerTemplate">
      <div class="O_ColorPicker">
        <div
          class="M_ColorPickerHistogram"
          data-fill-form-index-param=""
          data-action="click->fill-form#handleHueChange">
          
          <div class="A_ColorPickerHistogramThumb"></div>
        </div>

        <div class="W_ColorPickerParams">
          <div class="M_ColorPickerSlider hue">
            <div class="A_ColorPickerSliderThumb"></div>
          </div>

          <div class="M_ColorPickerSlider alpha">
            <div class="A_ColorPickerSliderThumb"></div>
          </div>

          <div class="M_ColorPickerResult">
            <div class="W_ColorPickerResultField">
              <label for="redColor">R</label>
              <input type="text" name="redColor" id="redColor">
            </div>

            <div class="W_ColorPickerResultField">
              <label for="greenColor">G</label>
              <input type="text" name="greenColor" id="greenColor">
            </div>

            <div class="W_ColorPickerResultField">
              <label for="blueColor">B</label>
              <input type="text" name="blueColor" id="blueColor">
            </div>

            <div class="W_ColorPickerResultField">
              <label for="alphaColor">A</label>
              <input type="text" name="alphaColor" id="alphaColor">
            </div>
          </div>
        </div>
      </div>
    </template>

    <template data-fill-form-target="newColorTemplate">
      <div data-fill-form-target="fillColor">
        <div>
          <label for="rgb_hash">Заливка</label>
          <input type="text" name="rgb_hash" id="rgb_hash">
        </div>

        <div data-fill-form-target="fillColorStop" class="fillColorStop"></div>
      </div>
    </template>

    <template data-fill-form-target="colorStopTemplate">
      <div>
        <label for="stop">Стоп</label>

        <input
          data-fill-form-target="colorStopInput"
          data-fill-form-index-param=""
          data-action="input->fill-form#changeFillColorStop"
          class="changeFillColorStop"
          type="range"
          min="0"
          max="100"
          step="1"
          name="stop"
          id="stop"
          placeholder="stop">
      </div>
    </template>

    <div id="fill_colors" data-fill-form-target="fillColors">
      <% fill.fill_colors.each do |fill_color| %>
        <%= render partial: "fills/form_fill_color", locals: { fill_color: fill_color } %>
      <% end %>
    </div>

    <div>
      <div
        class="plusButton"
        data-action="click->fill-form#addColor"
        data-fill-form-url-param="<%= add_fill_color_fills_url %>">
          + Добавить заливку
      </div>
    </div>
  </div>

  <%#= turbo_frame_tag "fill_colors" %>

  <div>
    <%= form.submit %>
  </div>
<% end %>
